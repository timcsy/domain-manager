# Kubernetes Domain Manager - Environment Variables

# Application Settings
PORT=8080
LOG_LEVEL=info

# Database Settings
DATABASE_PATH=./data/database.db

# Kubernetes Settings
K8S_IN_CLUSTER=false
K8S_MOCK=true              # Set to true for local development without K8s cluster
# KUBECONFIG=/path/to/kubeconfig

# Admin Settings (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com

# Let's Encrypt Settings
LETSENCRYPT_EMAIL=
LETSENCRYPT_SERVER=https://acme-v02.api.letsencrypt.org/directory
# For testing: https://acme-staging-v02.api.letsencrypt.org/directory

# Ingress Settings
DEFAULT_INGRESS_CLASS=nginx
CERT_MANAGER_ENABLED=true

# Security
# ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Development
# GIN_MODE=debug
